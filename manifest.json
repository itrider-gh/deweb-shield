{
  "manifest_version": 3,
  "name": "DeWeb Shield",
  "version": "0.2.2",
  "description": "Protect Massa DeWeb browsing with external-call blocking, CSP checks, and trusted-node integrity status.",
  "icons": {
    "16": "icons/deweb-shield-16.png",
    "32": "icons/deweb-shield-32.png",
    "48": "icons/deweb-shield-48.png",
    "128": "icons/deweb-shield-128.png"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "declarativeNetRequest",
    "storage",
    "tabs",
    "webRequest",
    "webRequestBlocking"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "deweb-integrity.js",
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "DeWeb Shield",
    "default_icon": {
      "16": "icons/deweb-shield-16.png",
      "32": "icons/deweb-shield-32.png",
      "48": "icons/deweb-shield-48.png",
      "128": "icons/deweb-shield-128.png"
    },
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "deweb-shield@example.local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
